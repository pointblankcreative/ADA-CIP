# =============================================================================
# CIP Environment Variables
# Copy to .env and fill in values
# =============================================================================

# GCP
GCP_PROJECT_ID=point-blank-ada
GCP_REGION=northamerica-northeast1
BIGQUERY_DATASET=cip

# Google credentials (path to service account JSON or leave blank for ADC)
GOOGLE_APPLICATION_CREDENTIALS=

# Cloud SQL (for app state — users, sessions, settings)
CLOUD_SQL_CONNECTION_NAME=
CLOUD_SQL_DATABASE=cip
CLOUD_SQL_USER=
CLOUD_SQL_PASSWORD=

# Firebase Auth
FIREBASE_PROJECT_ID=point-blank-ada

# Slack
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# Google Sheets (path to service account JSON for media plan sync)
SHEETS_SERVICE_ACCOUNT_FILE=

# App
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
